  ],
  "screenshots": [
    { "src": "assets/EXPLORE.jpg", "sizes": "720x900", "type": "image/jpeg", "form_factor": "narrow", "label": "Run across live market candles as Finn" },
    { "src": "assets/TRADE.jpg",   "sizes": "720x900", "type": "image/jpeg", "form_factor": "narrow", "label": "Read the setup and pick a side" },
    { "src": "assets/BATTLE.jpg",  "sizes": "720x900", "type": "image/jpeg", "form_factor": "narrow", "label": "Defeat the Guardians" }
