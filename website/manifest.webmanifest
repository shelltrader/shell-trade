{
  "id": "/",
  "name": "ChartQuest — The World's First Trading RPG",
  "short_name": "ChartQuest",
  "description": "Dive inside real market charts as Finn the turtle. Run the candles, read the setups, defeat the Guardians — and learn to trade. Free, in your browser.",
  "lang": "en",
  "dir": "ltr",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "any",
  "background_color": "#060910",
  "theme_color": "#060910",
  "prefer_related_applications": false,
  "categories": ["games", "education", "finance"],
  "icons": [
    { "src": "assets/pwa/icon-96.png",  "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "assets/pwa/icon-128.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
